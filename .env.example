# Скопируй в .env и впиши значения:  cp .env.example .env
# .env в git НЕ коммитится (см. .gitignore).

# --- LLM-провайдер ---
# claude (прод) или gemini (бесплатно для тестов)
COMPOSER_PROVIDER=gemini

# Ключ Anthropic (для COMPOSER_PROVIDER=claude)
ANTHROPIC_API_KEY=

# Ключ Gemini — бесплатно на https://aistudio.google.com (для тестов и эмбеддингов)
GEMINI_API_KEY=

# --- Безопасность ---
# В проде ОБЯЗАТЕЛЬНО сменить на длинную случайную строку
EVERGREEN_JWT_SECRET=dev-only-change-me

# DATABASE_URL внутри docker-compose задаётся автоматически (сервис db),
# менять не нужно. Для запуска БЕЗ докера раскомментируй и поправь:
# EVERGREEN_DATABASE_URL=postgresql+psycopg://evergreen:evergreen@localhost:5432/evergreen
